 "doctype": "Print Format",
 "font_size": 14,
 "html": "{%- from \"templates/print_formats/standard_macros.html\" import add_header, render_field, print_value, fieldmeta, get_width, get_align_class with context -%}\n\n{% if print_settings.repeat_header_footer %}\n    <div id=\"header-html\">\n        {% if letter_head and not no_letterhead %}\n            <div class=\"letter-head\">{{ letter_head }}</div>\n        {% else%}\n             <div>\n               <table>\n                <tr></tr>\n               </table>\n               </div>\n        {% endif %}\n   </div>\n{% endif %}\n\n<head>\n    <meta name=\"pdfkit-page-width\" content=\"3.4in\"/>\n    <meta name=\"pdfkit-page-height\" content=\"18in\"/>\n</head>\t\n\n{% set img = namespace(url = \"\")%}\n{% if doc.bom_no %}\n    {% set img.url = frappe.db.get_value(\"BOM\", doc.bom_no, \"custom_bom_image_\") or \"\"%}\n{%endif%}   \n\n<div style=\"padding-right:10px !important;\">\n    <table>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Stock Entry Type </td>\n            <td colspan=\"1\" style=\"padding-left: 10px !important;\">{{ doc.stock_entry_type or \"\" }}</td>\n            {% if img.url != \"\" %}\n            <td colspan=\"2\" rowspan=\"9\"><img src={{img.url or \"\"}} alt=\"BOM Image\"/></td>\n            {%endif%}\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Stock Entry ID </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.name or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Posting Date </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.posting_date or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Posting Time </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ frappe.format(doc.posting_time, \"Time\") or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Workflow State </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.workflow_state or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Work Order </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.work_order or \"\" }}</td>\n        </tr>\n        <tr>\n            {% set manufacture_count = frappe.db.get_value(\"Work Order\",doc.work_order,\"custom_manufacture_count\")%}\n            <td colspan=\"1\" style=\"font-weight:600;\">Manufacture Count </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ manufacture_count or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Manufacture Weight</td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ frappe.db.get_value(\"Work Order\", doc.work_order, \"qty\") or \"\" }}</td>\n        </tr>\n        {% if doc.custom_manufacture_qty %}\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">Manufacture Qty </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.custom_manufacture_qty or \"\" }}</td>\n        </tr>\n        {% endif %}\n        <tr>\n            {% set size = frappe.db.get_value(\"Work Order\",doc.work_order,\"custom_item_size\")%}\n            <td colspan=\"1\" style=\"font-weight:600;\">Item Size </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ size or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">BOM Name </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">{{ doc.bom_no or \"\" }}</td>\n        </tr>\n        <tr>\n            <td colspan=\"1\" style=\"font-weight:600;\">User Information </td>\n            <td colspan=\"3\" style=\"padding-left: 10px !important;\">\n                {% set user = frappe.db.get_value(\"Workflow Action\", {\"workflow_state\" : doc.workflow_state, \"reference_doctype\" : \"Stock Entry\", \"reference_name\" : doc.name}, \"owner\") %}\n                {{ frappe.db.get_value(\"User\", {\"email\" : user}, \"full_name\") or \"\" }}\n            </td>\n        </tr>\n    \n    </table>\n    \n    <div style=\"display:flex; gap:5px;\">\n        <table>\n        {% set data = get_previous_manufacture_data(doc.work_order, doc.stock_entry_type, doc.posting_date, doc.posting_time) %}\n        {% set total_previous_issued_qty = 0 %}\n        {% set total_previous_pure_qty = 0 %}\n        {% if data != {} %}\n            {% set total_previous_issued_qty = data['total_issued_qty'] %}\n            {% set total_previous_pure_qty = data['total_pure_qty'] %}\n        {% endif %}\n        \n        <tr>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Total Issue Against WO</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Previous</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Current</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Total Stock Entry</td>\n        </tr>\n        \n        <tr>\n            <td style=\"border:1px solid black; text-align:center;\"></td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(total_previous_issued_qty) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.items|sum(\"qty\")) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.items|sum(\"qty\") + total_previous_issued_qty) or \"\" }}</td>\n        </tr>\n        </table>\n        \n        <table>\n        {% set qty = get_previous_manufacture_qty(doc.work_order, doc.stock_entry_type, doc.posting_date, doc.posting_time) %}\n        {% set prev_qty = 0 %}\n        {% if qty !={} %}\n            {% set prev_qty = qty['total_previous_manufacture_qty'] %}\n        {% endif %}\n        <tr>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Issue Qty</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Previous Qty</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Current Qty</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Total Manufacture Qty</td>\n        </tr>\n        \n        <tr>\n            <td style=\"border:1px solid black; text-align:center;\"></td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(prev_qty) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.custom_manufacture_qty) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.custom_manufacture_qty + prev_qty) or \"\" }}</td>\n        </tr>\n        </table>\n    </div>\n    \n    <table>\n        <tr>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Pure-995</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Previous</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Current</td>\n            <td style=\"border:1px solid black; text-align:center; font-weight:bold;\">Total Pure-995</td>\n        </tr>\n        \n        <tr>\n            <td style=\"border:1px solid black; text-align:center;\"></td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(total_previous_pure_qty) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.items|sum(\"custom_pure_qty\")) or \"\" }}</td>\n            <td style=\"border:1px solid black; text-align:center;\">{{ \"%.2f\"|format(doc.items|sum(\"custom_pure_qty\") + total_previous_pure_qty) or \"\" }}</td>\n        </tr>\n        \n        <tr>\n            <td style=\"padding-bottom:12px !important\"></td>\n            <td style=\"padding-bottom:12px !important\"></td>\n            <td style=\"padding-bottom:12px !important\"></td>\n            <td style=\"padding-bottom:12px !important\"></td>\n        </tr>\n        \n        {% for item in doc.items %}\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-top:1px solid black; border-left:1px solid black;\">Source Warehouse </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-top:1px solid black; border-right:1px solid black;\">{{ item.s_warehouse or \"\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-left:1px solid black;\">Target Warehouse </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-right:1px solid black;\">{{ item.t_warehouse or \"\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-left:1px solid black;\">Item Code </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-right:1px solid black;\">{{ item.item_code or \"\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-left:1px solid black;\">Description </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-right:1px solid black;\">{{ item.description or \"\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-left:1px solid black;\">Weight </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-right:1px solid black;\">{{ \"%.2f\"|format(item.qty) or \"\"}}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-left:1px solid black;\">Issue Qty </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-right:1px solid black;\">{{ item.custom_issue_qty or 0 }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"1\" style=\"font-weight:600; border-bottom:1px solid black; border-left:1px solid black;\">Purity 99.5 </td>\n                <td colspan=\"3\" style=\"padding-left: 10px !important; border-bottom:1px solid black; border-right:1px solid black;\">{{ \"%.2f\"|format(item.custom_pure_qty) or 0 }}</td>\n            </tr>\n        {% endfor %}\n        \n    </table>\n</div>\n\n{% if print_settings.repeat_header_footer %}\n<div id=\"footer-html\">\n    {% if footer %}\n    <div class=\"letter-head-footer\"> {{ footer }} </div>\n    {% endif %}\n</div>\n{% endif %}",
