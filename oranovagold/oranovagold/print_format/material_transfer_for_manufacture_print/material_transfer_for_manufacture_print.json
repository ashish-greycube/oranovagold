 "css": "table {\n    width:100%;\n    table-layout:fixed;\n    border:none;\n    color:black;\n    font-size:9px;\n    margin-top:15px;\n}\n\n\n\n.print-format td {\n    padding:3px !important;\n}\n\ntd img {\n    height:200px;\n    /*width:200px;*/\n}\n",
 "custom_format": 1,
 "default_print_language": "en",
